from PyQt5.QtWidgets import QApplication, QWidget, QVBoxLayout, QHBoxLayout, QLabel, QPushButton, QLineEdit
from PyQt5.QtCore import Qt, QTimer
from PyQt5.QtGui import QPalette, QBrush, QPixmap

ANCHO, ALTO = 700, 500
COR_X, COR_Y = 200, 200
TITULO = 'PyQt5 - JoJo Villains Edition'
INPUT_TEXT = 'Invoca un Stand...'
BTN_TEXT = 'Activar'

class MainWindow(QWidget):
    def __init__(self, parent=None, flags=Qt.WindowFlags()):
        super().__init__(parent=parent, flags=flags)

        self.imagen_actual = 'dio.jpg'  # DIO es el jefe por defecto
        self.config_window()
        self.set_window()
        self.event_handler()
        self.show()

    def set_window(self): 
        # Cajas de texto y botones
        self.input = QLineEdit()
        self.input.setPlaceholderText(INPUT_TEXT)
        self.input.setStyleSheet("font-size: 16px; padding: 5px;")
        
        self.btn = QPushButton(BTN_TEXT)
        self.btn.setStyleSheet("font-size: 16px; padding: 5px; font-weight: bold;")
        
        self.label = QLabel('¿Qué Stand dominará esta interfaz?')
        self.label.setAlignment(Qt.AlignCenter)
        self.aplicar_estilo_label("#FFD700")  # Dorado por defecto

        # Layouts
        controles_layout = QHBoxLayout()
        controles_layout.addWidget(self.input)
        controles_layout.addWidget(self.btn)

        layout_principal = QVBoxLayout()
        layout_principal.addLayout(controles_layout)
        layout_principal.addWidget(self.label)

        self.setLayout(layout_principal)

    def config_window(self):
        self.setGeometry(COR_X, COR_Y, ANCHO, ALTO)
        self.setWindowTitle(TITULO)
        self.poner_fondo(self.imagen_actual)

    def poner_fondo(self, ruta_imagen):
        """Cambia el fondo dinámicamente según el villano activo"""
        try:
            palette = QPalette()
            pixmap = QPixmap(ruta_imagen).scaled(ANCHO, ALTO, Qt.IgnoreAspectRatio, Qt.SmoothTransformation)
            palette.setBrush(QPalette.Background, QBrush(pixmap))
            self.setPalette(palette)
        except Exception:
            # Si no encuentra la imagen, usa un gris oscuro de respaldo
            self.setStyleSheet("background-color: #222222;")

    def aplicar_estilo_label(self, color_texto):
        """Estilo de texto Jojo genérico con color personalizado"""
        self.label.setStyleSheet(f"""
            font-size: 22px; 
            font-weight: bold; 
            color: {color_texto}; 
            background-color: rgba(0, 0, 0, 180); 
            border-radius: 10px;
            padding: 12px;
        """)

    def event_handler(self):
        self.btn.clicked.connect(self.procesar_conjuro)
        self.input.returnPressed.connect(self.procesar_conjuro)

    def procesar_conjuro(self):
        text = self.input.text().strip().upper()
        self.input.clear()

        # Ocultar controles durante los efectos de los Stands
        self.input.hide()
        self.btn.hide()

        # --- selector de STANDS ---
        if text == "ZA WARUDO":
            self.efecto_za_warudo()
        elif text == "BITES THE DUST":
            self.efecto_bites_the_dust()
        elif text == "KING CRIMSON":
            self.efecto_king_crimson()
        elif text == "MADE IN HEAVEN":
            self.efecto_made_in_heaven()
        else:
            # Si no es un conjuro, DIO te responde y los controles regresan inmediatamente
            self.label.setText(f"DIO dice: No tienes el poder de un Stand...")
            self.input.show()
            self.btn.show()

    # --- 1. DIO: ZA WARUDO (7 Segundos) ---
    def efecto_za_warudo(self):
        self.imagen_actual = 'dio.jpg'
        self.setStyleSheet("background-color: black;")
        self.label.setText("¡¡ZA WARUDO!! El tiempo se ha detenido...")
        self.label.setStyleSheet("font-size: 28px; color: #00FFFF; background-color: transparent;")
        QTimer.singleShot(7000, self.restaurar_todo)

    # --- 2. KIRA: BITES THE DUST (Explosión y reinicio en 4 segundos) ---
    def efecto_bites_the_dust(self):
        self.imagen_actual = 'kira.jpg'
        self.poner_fondo(self.imagen_actual)
        self.label.setText("¡KILLER QUEEN! Tercera bomba: ¡Bites the Dust!")
        self.aplicar_estilo_label("#FF69B4") # Rosa Killer Queen
        
        # Efecto de flash de explosión a los 2 segundos
        QTimer.singleShot(2000, lambda: self.setStyleSheet("background-color: #FF4500;"))
        QTimer.singleShot(2100, lambda: self.setStyleSheet("background-color: white;"))
        
        # El tiempo retrocede y limpia la pantalla a los 4 segundos
        QTimer.singleShot(4000, self.restaurar_todo)

    # --- 3. DIAVOLO: KING CRIMSON (Borra el tiempo por 3 segundos) ---
    def setup_king_crimson_visual(self):
        self.setStyleSheet("background-color: #4A0000;") # Rojo carmesí espacio borrado
        self.label.setText("He borrado el tiempo y saltado más allá de él...")
        self.label.setStyleSheet("font-size: 24px; color: #FF0000; background-color: transparent;")

    def efecto_king_crimson(self):
        self.imagen_actual = 'diavolo.jpg'
        self.poner_fondo(self.imagen_actual)
        self.label.setText("¡KING CRIMSON!")
        self.aplicar_estilo_label("#FF0055")
        
        # Salto temporal abrupto a los 1.5 segundos
        QTimer.singleShot(1500, self.setup_king_crimson_visual)
        QTimer.singleShot(4500, self.restaurar_todo)

    # --- 4. PUCCI: MADE IN HEAVEN (Aceleración del universo por 5 segundos) ---
    def simular_aceleracion(self, paso):
        """Simula parpadeos veloces del universo acelerando"""
        if paso < 10:
            color = "white" if paso % 2 == 0 else "black"
            self.setStyleSheet(f"background-color: {color};")
            self.label.setText(f"Aceleración del Universo: x{paso * 1000}!!")
            QTimer.singleShot(200, lambda: self.simular_aceleracion(paso + 1))
        else:
            self.restaurar_todo()

    def efecto_made_in_heaven(self):
        self.imagen_actual = 'pucci.jpg'
        self.poner_fondo(self.imagen_actual)
        self.label.setText("¡El destino ha sido guiado... MADE IN HEAVEN!")
        self.aplicar_estilo_label("#DA70D6") # Violeta Pucci
        
        # Inicia la secuencia de aceleración loca
        QTimer.singleShot(1500, lambda: self.simular_aceleracion(0))


    def restaurar_todo(self):
        """Regresa la interfaz a su estado normal con el villano correspondiente"""
        self.setStyleSheet("") # Quita fondos de colores sólidos
        self.poner_fondo(self.imagen_actual)
        
        self.input.show()
        self.btn.show()
        
        # Colores personalizados para el texto final según quién quedó activo
        colores = {'dio.jpg': '#FFD700', 'kira.jpg': '#FF69B4', 'diavolo.jpg': '#FF0055', 'pucci.jpg': '#DA70D6'}
        
        self.label.setText("El flujo de la realidad ha vuelto a la normalidad.")
        self.aplicar_estilo_label(colores.get(self.imagen_actual, "#FFFFFF"))

def run():
    app = QApplication([])
    main_window = MainWindow()
    app.exec_()

if __name__ == "__main__":
    run()
